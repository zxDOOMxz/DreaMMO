# ========== DATABASE ==========
# PostgreSQL подключение (Neon.tech или локально)
DATABASE_URL=postgresql://user:password@localhost:5432/dreammo

# ========== JWT & SECURITY ==========
JWT_SECRET=your_super_secret_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== RATE LIMITING ==========
RATE_LIMIT_ACTIONS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ========== DEBUG ==========
DEBUG=True

# ========== CORS ==========
# Frontend origin для локальной разработки
CORS_ORIGIN=http://localhost:5173
